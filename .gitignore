# Dev Home Assistant instance: commit only configuration.yaml; everything else
# HA writes here (database, .storage, onboarding, secrets) — plus the
# custom_components symlink scripts/develop creates — stays out of git.
/config/*
!/config/configuration.yaml

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Thumbnails
._*

# IntelliJ IDEA
.idea
*.iml

# Caches
.pytest_cache
.cache
.ruff_cache

# Python bytecode
*.py[cod]
__pycache__

# C extensions
*.so

# Packaging
*.egg
*.egg-info
dist
build
eggs
.eggs
parts
bin
var
sdist
develop-eggs
.installed.cfg
lib
lib64

# Logs
*.log
pip-log.txt

# Unit test / coverage reports
.coverage
.coverage.*
coverage.xml
nosetests.xml
htmlcov/
junit.xml

# Translations (compiled catalogs; the committed en.json is a deliverable)
*.mo

.python-version
.tool-versions

# Editor backups
*~
*#
*.orig

# venv
pyvenv.cfg
pip-selfcheck.json
venv
.venv
Pipfile*

# vim
*.swp
*.swo
tags
ctags.tmp

# Visual Studio Code
.vscode/*
.env

# Windows Explorer
desktop.ini

# mypy
/.mypy_cache/*
/.dmypy.json

# AI tooling
.claude
